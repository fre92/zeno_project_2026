<launch>

    <rosparam command="load" file="$(find zeno_python)/config/waypoints.yaml" />
    <rosparam command="load" file="$(find zeno_python)/config/targets.yaml" />
    <rosparam command="load" file="$(find zeno_python)/config/obstacles.yaml" />



    <!-- lancia controllore -->
    <node pkg="zeno_python" type="path_controller.py" name="path_controller" output="screen"/>

    <!-- lancia plot -->
    <node pkg="zeno_python" type="plot_completo.py" name="nav_plot_completo" output="screen" />

    <node pkg="zeno_python" type="planner_astar.py" name="planner_astar" output="screen" />

   


</launch>